# Environment variables for Artivio Command Center

# Database
# Local database with PGLite, already included in the project, no Docker needed
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres

# Next.js
NEXT_TELEMETRY_DISABLED=1

# Logging
NEXT_PUBLIC_LOGGING_LEVEL=debug

######## [BEGIN] SENSITIVE DATA ######## For security reasons, don't put secrets
######## in this file. Create `.env.local` (git-ignored) and add them there.
# Session auth (required at runtime, not at build):
# SESSION_SECRET=<random string, 32+ chars>  — in production this lives in Railway variables
######## [END] SENSITIVE DATA
